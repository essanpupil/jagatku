local.file_match "debian_logs" {
  path_targets = [
    { "__path__" = "/var/log/**.log" },
  ]
}

loki.source.file "local_files" {
  targets    = local.file_match.debian_logs.targets
  forward_to = [loki.write.loki_endpoint.receiver]
}

loki.write "loki_endpoint" {
  endpoint {
    url = "{{ loki_url }}"
  }
}

loki.source.journal "system" {
  forward_to = [loki.process.filter_noisy_logs.receiver]
  format_as_json = true

}

loki.process "filter_noisy_logs" {
  forward_to = [loki.write.loki_endpoint.receiver]
  stage.drop {
    source = "MESSAGE"
    value = "syslogin_perform_logout: logout() returned an error"
    drop_counter_reason = "ansible_ssh_logout_noise"
  }
}

discovery.relabel "vault" {
	targets = [{
		__address__ = "{{ ansible_host }}:8200",
	}]

	rule {
		target_label = "instance"
		replacement  = constants.hostname
	}
}

prometheus.scrape "vault" {
  forward_to = [prometheus.remote_write.default.receiver]
  targets = discovery.relabel.vault.output
  scheme = "http"
  job_name = "vault"
  scrape_interval = "10s"
  scrape_timeout = "5s"
  params = {
    format = ["prometheus"],
  }
  metrics_path = "/v1/sys/metrics"
  
  // Vault metrics require authentication via a token
  // with the prometheus-metrics ACL policy
  // bearer_token = "YOUR_VAULT_TOKEN_HERE" 
}

prometheus.remote_write "default" {
  endpoint {
    url = "http://192.168.1.2:9090/api/v1/write"
    // basic_auth {
    //   username = "your-username"
    //   password = "your-password"
    // }
  }
}

// Scrape local Linux system metrics
prometheus.exporter.unix "local_system" { }

// Collect and label the metrics
prometheus.scrape "linux_metrics" {
  targets    = prometheus.exporter.unix.local_system.targets
  forward_to = [prometheus.remote_write.default.receiver]
}

discovery.consul "consul" {
  server = "{{ ansible_host }}:8500"
}

prometheus.relabel "filter_consul_rpc" {
  forward_to = [prometheus.scrape.consul.receiver]

  // Drop targets trying to scrape port 8300
  rule {
    source_labels = ["__address__"]
    regex         = ".*:8300"
    action        = "drop"
  }
}

prometheus.scrape "consul" {
  targets    = prometheus.relabel.filter_consul_rpc.output
  forward_to = [prometheus.remote_write.default.receiver]
}

discovery.consulagent "consulagent" {
  server = "{{ ansible_host }}:8500"
}


prometheus.relabel "filter_consulagent_rpc" {
  forward_to = [prometheus.scrape.consulagent.receiver]

  // Drop targets trying to scrape port 8300
  rule {
    source_labels = ["__address__"]
    regex         = ".*:8300"
    action        = "drop"
  }
}

prometheus.scrape "consulagent" {
  targets    = prometheus.relabel.filter_consulagent_rpc.output
  forward_to = [prometheus.remote_write.default.receiver]
}

