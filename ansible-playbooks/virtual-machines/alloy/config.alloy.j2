local.file_match "debian_logs" {
  path_targets = [
    { "__path__" = "/var/log/**.log" },
  ]
}

loki.source.file "local_files" {
  targets    = local.file_match.debian_logs.targets
  forward_to = [loki.write.loki_endpoint.receiver]
}

loki.write "loki_endpoint" {
  endpoint {
    url = "{{ loki_url }}"
  }
}

loki.source.journal "system" {
  forward_to = [loki.process.filter_noisy_logs.receiver]
  format_as_json = true

}

loki.process "filter_noisy_logs" {
  forward_to = [loki.write.loki_endpoint.receiver]
  stage.drop {
    source = "MESSAGE"
    value = "syslogin_perform_logout: logout() returned an error"
    drop_counter_reason = "ansible_ssh_logout_noise"
  }
}

prometheus.remote_write "default" {
  endpoint {
    url = "http://192.168.1.2:9090/api/v1/write"
    // basic_auth {
    //   username = "your-username"
    //   password = "your-password"
    // }
  }
}

// Scrape local Linux system metrics
prometheus.exporter.unix "local_system" { }

// Collect and label the metrics
prometheus.scrape "linux_metrics" {
  targets    = prometheus.exporter.unix.local_system.targets
  forward_to = [prometheus.remote_write.default.receiver]
}

discovery.docker "linux" {
  host = "unix:///var/run/docker.sock"
}

loki.source.docker "default" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.docker.linux.targets
  labels     = {"app" = "docker"}
  forward_to = [loki.write.loki_endpoint.receiver]
}

discovery.kubelet "k8s_pods" {
  url = "https://{{ ansible_host }}:10250"
}

prometheus.scrape "kubelet" {
  targets    = discovery.kubelet.k8s_pods.targets
  forward_to = [prometheus.remote_write.default.receiver]
  scheme = "https"
  tls_config {
    // ca_file            = "/var/lib/kubelet/pki/kubelet-client-2026-06-25-18-27-48.pem"
    cert_file          = "/etc/kubernetes/pki/apiserver.crt"
    key_file           = "/etc/kubernetes/pki/apiserver.key"
    // server_name        = "kubernetes"                  // Override if SANs do not match node IPs
    insecure_skip_verify = true
  }
  // bearer_token_file = "/var/run/secrets/kubernetes.io/serviceaccount/token"
}
